# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.
# See CLAUDE.md — Security section.

# Supabase (required — get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API — document generation agents)
ANTHROPIC_API_KEY=

# Brave Search API — fallback web search for agents (optional; Anthropic native search is primary)
# Get key at: https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=
# Email address to receive operator notifications (intake-complete, all-docs-generated, multi-user-signup-attempt)
RESEND_OPERATOR_EMAIL=
# From address for transactional emails (must match your verified Resend sending domain)
# Use display-name format: "Name <address@your-domain.com>"
RESEND_FROM_EMAIL=
# Where replies to transactional emails land. Should be a real, monitored inbox.
# Falls back to RESEND_FROM_EMAIL if unset.
REPLY_TO_EMAIL=

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Instantly (cold email webhooks)
INSTANTLY_WEBHOOK_SECRET=
INSTANTLY_API_KEY=

# Instantly API base URL — controls which server Prompt 3B handlers call.
# Leave unset in development: defaults to Instantly's public mock server
#   (https://developer.instantly.ai/_mock/api/v2) — no subscription or API key required.
# Set to https://api.instantly.ai/api/v2 once Instantly Growth subscription is active
#   AND the instantly_api_active flag in integrations_registry is flipped to true.
# Never set to the mock URL in production — the production default is the live API.
INSTANTLY_API_BASE_URL=

# Lemlist (LinkedIn DMs)
LEMLIST_WEBHOOK_SECRET=
LEMLIST_API_KEY=

# Apollo (prospect enrichment)
APOLLO_API_KEY=

# GoHighLevel
GHL_WEBHOOK_SECRET=
GHL_API_KEY=

# Internal server-to-server calls (e.g. /api/intake/complete dispatching agent routes)
# Generate with: openssl rand -hex 32
NEXT_INTERNAL_SECRET=

# Supabase Database Webhook shared secret (for /api/webhooks/users-pending-review-notify)
# Must match the secret set when configuring the webhook in Supabase Dashboard
# Header name used in Supabase Dashboard webhook config: x-webhook-secret
SUPABASE_PENDING_REVIEW_WEBHOOK_SECRET=
